# Local dev: leave both unset to use a local SQLite file at ../data/leverage.db
# Production (Vercel): set these (Project Settings -> Environment Variables)
# to point the backend at your Turso database instead.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Comma-separated list of origins allowed to call the API. Only needed for
# local dev (frontend and backend on different ports); in production behind
# Vercel Services the two are same-origin and this is unused.
LEVERAGE_CORS=http://localhost:3000
